# Required — shared secret enforced on every authenticated route and on the
# WebSocket handshake (via x-api-key header or ?api_key= query string).
PI_NOTIFICATION_RELAY_API_KEY=change-me

# Optional — TCP port to bind to. Defaults to 48291 if unset.
# PI_NOTIFICATION_RELAY_PORT=48291

# Optional — network interface to bind to. Defaults to 127.0.0.1.
# Set to 0.0.0.0 to expose on the LAN.
# PI_NOTIFICATION_RELAY_HOST=127.0.0.1

# Optional — Node environment. Affects log verbosity.
# NODE_ENV=development
